# AI Agent Engineering Platform environment template
# Copy this file to .env and fill in your own credentials.
# Never commit real API keys or server passwords.

# Required if you use DashScope as the default provider.
DASHSCOPE_API_KEY=your-dashscope-api-key

# Optional providers. These can also be configured from the frontend Settings page.
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional server-side default chat model override.
# Example provider values: dashscope, openai, anthropic, openai-compatible.
# DEFAULT_CHAT_PROVIDER=openai-compatible
# DEFAULT_CHAT_API_KEY=your-compatible-api-key
# DEFAULT_CHAT_MODEL=qwen-plus
# For Spring AI OpenAI-compatible clients, omit the trailing /v1 if the SDK appends it.
# DEFAULT_CHAT_BASE_URL=https://example.com/compatible-mode

# Optional RAG startup behavior. Set false when the embedding provider is unavailable.
# RAG_INDEX_ON_STARTUP=true

# Optional search API. If empty, the search tool falls back to HTML-based engines.
# TAVILY_API_KEY=your-tavily-api-key

# Optional MCP map service.
# AMAP_MAPS_API_KEY=your-amap-key

# Optional PostgreSQL + PGVector configuration.
# PGVECTOR_URL=jdbc:postgresql://localhost:5432/ai_agent
# PGVECTOR_USERNAME=your-db-user
# PGVECTOR_PASSWORD=your-db-password
