# ===========================================
# AI Research Assistant Agent — 环境变量配置
# 复制此文件为 .env 并填入真实值
# ===========================================

# 阿里云 DashScope API Key（必填，默认 Provider）
# 获取地址: https://help.aliyun.com/zh/model-studio/get-api-key
DASHSCOPE_API_KEY=sk-your-key-here

# OpenAI API Key（可选，通过前端 Settings 切换 Provider）
# 获取地址: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-key-here

# Anthropic API Key（可选，通过前端 Settings 切换 Provider）
# 获取地址: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-your-key-here

# 高德地图 API Key（可选，用于 MCP 地图服务）
# 获取地址: https://lbs.amap.com/api/webservice/create-project-and-key
# AMAP_MAPS_API_KEY=your-amap-key-here

# PostgreSQL + PGVector 数据库配置（可选，启用 RAG 持久化时需要）
# PGVECTOR_URL=jdbc:postgresql://localhost:5432/ai_agent
# PGVECTOR_USERNAME=your-db-user
# PGVECTOR_PASSWORD=your-db-password
